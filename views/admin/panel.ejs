<%- include('../partials/header') %>

<div class="page-head">
  <div>
    <p class="section-label">Panel administrador</p>
    <h1>Resumen de la quiniela</h1>
  </div>
  <div class="page-head-aside">
    <% if (settings.predictionsLocked) { %>
      <span class="tag tag-closed">Carga cerrada</span>
    <% } else { %>
      <span class="tag tag-open">Carga abierta</span>
    <% } %>
  </div>
</div>

<div class="stat-grid">
  <div class="card stat">
    <span class="stat-label">Socios registrados</span>
    <span class="stat-value"><%= membersCount %></span>
  </div>
  <div class="card stat">
    <span class="stat-label">Partidos cargados</span>
    <span class="stat-value"><%= matchesCount %></span>
  </div>
  <div class="card stat">
    <span class="stat-label">Partidos finalizados</span>
    <span class="stat-value"><%= finishedCount %></span>
  </div>
  <div class="card stat">
    <span class="stat-label">Puntuación</span>
    <span class="stat-value"><%= settings.pointsOutcome %> / <%= settings.pointsExact %></span>
    <span class="stat-foot">ganador / marcador exacto</span>
  </div>
</div>

<div class="action-grid">
  <a class="card action-card" href="<%= adminBase %>/socios">
    <h3>Socios</h3>
    <p>Da de alta socios y entrega su código de acceso.</p>
  </a>
  <a class="card action-card" href="<%= adminBase %>/partidos">
    <h3>Partidos</h3>
    <p>Edita equipos, fechas y carga los resultados oficiales.</p>
  </a>
  <a class="card action-card" href="<%= adminBase %>/puntuacion">
    <h3>Puntuación y cierre</h3>
    <p>Define los puntos y abre o cierra la carga de pronósticos.</p>
  </a>
  <a class="card action-card" href="<%= adminBase %>/posiciones">
    <h3>Posiciones</h3>
    <p>Consulta la tabla general de la quiniela.</p>
  </a>
</div>

<%- include('../partials/footer') %>
