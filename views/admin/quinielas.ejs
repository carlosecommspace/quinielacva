<%- include('../partials/header') %>

<div class="page-head">
  <div>
    <p class="section-label">Quinielas</p>
    <h1>Seguimiento de quinielas</h1>
  </div>
  <div class="page-head-aside">
    <span class="tag"><%= quinielas.length %> en total</span>
    <span class="tag tag-open"><%= paidCount %> pagadas</span>
    <span class="tag tag-closed"><%= quinielas.length - paidCount %> sin pagar</span>
  </div>
</div>

<div class="notice">
  Las quinielas <strong>pagadas</strong> son las que compiten en la tabla de
  posiciones. Cada quiniela cuesta <strong><%= cost %></strong>; valida el pago
  con el botón correspondiente cuando el socio pague a la administración.
</div>

<% if (!quinielas.length) { %>
  <div class="empty">Todavía no hay quinielas cargadas.</div>
<% } else { %>
  <div class="card table-card">
    <table class="table">
      <thead>
        <tr>
          <th>Socio</th>
          <th class="col-num">Acción</th>
          <th>Quiniela</th>
          <th class="col-num">Cargados</th>
          <th class="col-num">Puntos</th>
          <th>Pago</th>
          <th class="col-actions">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% quinielas.forEach(function (q) { %>
        <tr class="<%= q.paid ? '' : 'row-new' %>">
          <td><span class="member-name"><%= q.first_name %> <%= q.last_name %></span></td>
          <td class="col-num muted"><%= q.share_number %></td>
          <td><%= q.label %></td>
          <td class="col-num"><%= q.filled %> / <%= totalMatches %></td>
          <td class="col-num"><strong><%= q.points %></strong></td>
          <td>
            <% if (q.paid) { %>
              <span class="dot dot-ok"></span> Pagada
            <% } else { %>
              <span class="dot dot-idle"></span> No pagada
            <% } %>
          </td>
          <td class="col-actions">
            <a class="btn btn-ghost btn-sm" href="<%= adminBase %>/quinielas/<%= q.id %>">Ver / editar</a>
            <form method="post" action="<%= adminBase %>/quinielas/<%= q.id %>/pagar" class="inline-form">
              <input type="hidden" name="paid" value="<%= q.paid ? '0' : '1' %>" />
              <button type="submit" class="btn btn-<%= q.paid ? 'ghost' : 'primary' %> btn-sm">
                <%= q.paid ? 'Marcar no pagada' : 'Marcar pagada' %>
              </button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
