<%- include('../partials/header') %>

<div class="page-head">
  <div>
    <p class="section-label">Socios</p>
    <h1>Socios participantes</h1>
  </div>
  <div class="page-head-aside">
    <span class="tag"><%= members.length %> registrados</span>
  </div>
</div>

<div class="card card-pad">
  <h2 class="card-title">Dar de alta un socio</h2>
  <form method="post" action="<%= adminBase %>/socios" class="form-row">
    <div class="field">
      <label for="first_name">Nombre</label>
      <input type="text" id="first_name" name="first_name" required />
    </div>
    <div class="field">
      <label for="last_name">Apellido</label>
      <input type="text" id="last_name" name="last_name" required />
    </div>
    <div class="field">
      <label for="share_number">Número de acción</label>
      <input type="text" id="share_number" name="share_number" required />
    </div>
    <button type="submit" class="btn btn-primary">Crear socio</button>
  </form>
  <p class="form-hint">Al crear el socio se genera un código de acceso único (los 3 dígitos de su número de acción + 3 letras al azar) y una primera quiniela vacía. Entrégale el código para que ingrese y arme sus quinielas.</p>
</div>

<% if (!members.length) { %>
  <div class="empty">Todavía no hay socios. Crea el primero con el formulario de arriba.</div>
<% } else { %>
  <div class="card table-card">
    <table class="table">
      <thead>
        <tr>
          <th>Socio</th>
          <th class="col-num">Acción</th>
          <th>Código</th>
          <th class="col-num">Quinielas</th>
          <th class="col-num">Pagadas</th>
          <th>Estado</th>
          <th class="col-actions">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% members.forEach(function (m) {
             var c = counts.get(m.id) || { total: 0, paid: 0 };
        %>
        <tr class="<%= createdId === m.id ? 'row-new' : '' %>">
          <td><span class="member-name"><%= m.first_name %> <%= m.last_name %></span></td>
          <td class="col-num muted"><%= m.share_number %></td>
          <td><code class="code-chip"><%= m.code %></code></td>
          <td class="col-num"><%= c.total %></td>
          <td class="col-num">
            <%= c.paid %><% if (c.total - c.paid > 0) { %> <span class="muted">(<%= c.total - c.paid %> sin pagar)</span><% } %>
          </td>
          <td>
            <% if (m.first_access_at) { %>
              <span class="dot dot-ok"></span> Ingresó
            <% } else { %>
              <span class="dot dot-idle"></span> Sin ingresar
            <% } %>
          </td>
          <td class="col-actions">
            <a class="btn btn-ghost btn-sm" href="<%= adminBase %>/socios/<%= m.id %>">Ver quinielas</a>
            <form method="post" action="<%= adminBase %>/socios/<%= m.id %>/eliminar" class="inline-form"
                  onsubmit="return confirm('Eliminar a <%= m.first_name %> <%= m.last_name %> y todas sus quinielas?');">
              <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
