<%- include('../partials/header') %>

<div class="page-head">
  <div>
    <p class="section-label">Quiniela de un socio</p>
    <h1><%= target.first_name %> <%= target.last_name %></h1>
  </div>
  <div class="page-head-aside">
    <span class="tag">Acción <%= target.share_number %></span>
    <span class="tag tag-points"><%= points %> puntos</span>
