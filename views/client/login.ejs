<%- include('../partials/header') %>

<div class="auth-wrap">
  <div class="card auth-card">
    <p class="section-label">Portal del socio</p>
    <h1>Ingresa tu código</h1>
    <p class="muted">Usa el código de acceso que te entregó la administración del club.</p>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="flash flash-error"><%= error %></div>
    <% } %>

    <form method="post" action="/socio" class="stack">
      <div class="field">
        <label for="code">Código de acceso</label>
        <input type="text" id="code" name="code" class="code-input" autocomplete="off"
               autocapitalize="characters" spellcheck="false" maxlength="12"
               placeholder="Ej. K7M2QP" required autofocus />
      </div>
      <button type="submit" class="btn btn-primary btn-block">Entrar</button>
    </form>

    <p class="auth-alt">
      ¿Primera vez? <a href="/socio/registro">Crea tu quiniela aquí</a> con tu
      número de acción.
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
