# --- Quiniela CVA · variables de entorno ---

# Conexion a PostgreSQL. En Railway: agrega el plugin PostgreSQL y referencia
# la variable con ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgres://usuario:password@localhost:5432/quinielacva

# Pon "true" solo si tu conexion a Postgres exige SSL (URL publica de Railway).
# Si usas la URL interna del proyecto, dejalo en false.
DATABASE_SSL=false

# Contrasena del portal administrador. CAMBIALA antes de desplegar.
ADMIN_PASSWORD=cambia-esta-clave

# Ruta secreta del portal administrador. Por seguridad, el panel NO vive en la
# predecible /admin: define aqui una ruta dificil de adivinar (solo letras,
# numeros, ".", "_", "~" o "-"; un unico segmento, sin barras). El login queda
# en /<ADMIN_PATH> y el resto en /<ADMIN_PATH>/panel, /<ADMIN_PATH>/socios, etc.
# El socio mantiene su ruta publica /socio. Si no la defines, se usa "admin".
ADMIN_PATH=gestion-cva-2026

# Secreto para firmar las cookies de sesion. Usa una cadena larga y aleatoria.
SESSION_SECRET=cambia-este-secreto-largo-y-aleatorio

# Puerto (Railway lo asigna automaticamente).
PORT=3000
